{
    "name": "jolicode/castor",
    "description": "A lightweight and modern task runner. Automate everything. In PHP.",
    "keywords": ["task", "runner", "async", "parallel", "process", "castor"],
    "license": "MIT",
    "type": "project",
    "authors": [
        {
            "name": "Joel Wurtz",
            "email": "jwurtz@jolicode.com"
        },
        {
            "name": "Grégoire Pineau",
            "email": "lyrixx@lyrixx.info"
        },
        {
            "name": "Loïck Piera",
            "email": "pyrech@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Castor\\": "src/"
        },
        "files": [
            "src/functions.php",
            "src/functions-internal.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Castor\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.4",
        "composer/composer": "^2.10.1",
        "jolicode/jolinotif": "^3.3",
        "jolicode/php-os-helper": "^0.3.0",
        "laravel/agent-detector": "^2.0.2",
        "monolog/monolog": "^3.10.0",
        "nikic/php-parser": "^5.7.0",
        "phpstan/phpdoc-parser": "^2.3.2",
        "spatie/ssh": "^1.13.1",
        "symfony/cache": "^8.1",
        "symfony/config": "^8.1",
        "symfony/console": "^8.1",
        "symfony/dependency-injection": "^8.1",
        "symfony/deprecation-contracts": "^3.7.0",
        "symfony/dotenv": "^8.1",
        "symfony/error-handler": "^8.1",
        "symfony/expression-language": "^8.1",
        "symfony/filesystem": "^8.1",
        "symfony/finder": "^8.1",
        "symfony/http-client": "^8.1",
        "symfony/mime": "^8.1",
        "symfony/monolog-bridge": "^8.1",
        "symfony/process": "^8.1",
        "symfony/string": "^8.1",
        "symfony/translation-contracts": "^3.7.0",
        "symfony/var-dumper": "^8.1",
        "symfony/yaml": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.2"
    },
    "bin": [
        "bin/castor"
    ],
    "config": {
        "bump-after-update": true,
        "platform": {
            "php": "8.4.1"
        },
        "sort-packages": true
    }
}
